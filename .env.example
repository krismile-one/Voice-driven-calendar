# 语音日历助手配置文件
# 复制此文件为 .env 并填入实际配置

# ========== 数据库配置 ==========
DATABASE_URL=sqlite:///data/calendar.db

# ========== 语音识别配置 ==========
# 语音识别模式：online（在线）/ offline（离线，需安装vosk）/ hybrid（混合）
ASR_MODE=online

# ========== 在线语音识别配置 ==========
# 语音识别服务商：baidu（百度）/ xunfei（讯飞）
ASR_PROVIDER=baidu

# 语音识别应用ID（百度：应用AppID，讯飞：应用APPID）
ASR_APP_ID=
# 语音识别API Key（百度：API Key，讯飞：APIKey）
ASR_API_KEY=
# 语音识别Secret Key（百度：Secret Key，讯飞：APISecret）
ASR_SECRET_KEY=

# ========== 离线语音识别配置（可选，需安装vosk） ==========
# Vosk模型路径（仅离线模式需要）
VOSK_MODEL_PATH=models/vosk/vosk-model-small-cn-0.22

# ========== NLU大模型配置 ==========
# 大模型提供商（openai/anthropic，deepseek和mimo使用openai格式）
LLM_PROVIDER=openai
# 大模型API密钥
LLM_API_KEY=
# 大模型名称（如 deepseek-chat、mimo-chat）
LLM_MODEL=deepseek-chat
# 大模型API基础URL（用于兼容deepseek/mimo等）
# DeepSeek: https://api.deepseek.com
# Mimo: 根据实际API地址填写
LLM_BASE_URL=https://api.deepseek.com

# ========== 服务配置 ==========
HOST=0.0.0.0
PORT=8000

# ========== 提醒配置 ==========
# 提醒检查间隔（秒）
REMINDER_CHECK_INTERVAL=60
